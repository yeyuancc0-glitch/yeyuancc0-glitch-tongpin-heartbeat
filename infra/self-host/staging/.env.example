COMPOSE_PROJECT_NAME=tongpin-staging

APP_DOMAIN=tongpin.fancah.tech
API_DOMAIN=api-staging.fancah.tech
ASSETS_DOMAIN=assets-staging.fancah.tech
ACME_EMAIL=admin@example.com

API_ENV=staging
API_PORT=3000
AUTH_ACCESS_TOKEN_SECRET=change-me-at-least-32-characters-access-secret
AUTH_ACCESS_TOKEN_KEYS=
AUTH_ACCESS_TOKEN_CURRENT_KID=
AUTH_REFRESH_TOKEN_PEPPER=change-me-at-least-32-characters-refresh-pepper
AUTH_EMAIL_DELIVERY_CONFIGURED=false
EMAIL_PROVIDER=none
EMAIL_FROM=
RESEND_API_KEY=
AUTH_EMAIL_VERIFY_URL_BASE=
AUTH_PASSWORD_RESET_URL_BASE=

POSTGRES_DB=tongpin_staging
POSTGRES_USER=tongpin_app
POSTGRES_PASSWORD=change-me-postgres-password

REDIS_MAXMEMORY=256mb

MINIO_ROOT_USER=tongpin_minio
MINIO_ROOT_PASSWORD=change-me-minio-root-password
STORAGE_MAX_THUMBNAIL_UPLOAD_BYTES=1048576

# Supabase legacy data migration source.
# These are required only for `bash scripts/run-supabase-migration.sh`.
# Keep real values in the server-only .env; never expose them to frontend builds.
SUPABASE_DB_URL=
SUPABASE_STORAGE_S3_ENDPOINT=
SUPABASE_STORAGE_S3_REGION=
SUPABASE_STORAGE_S3_ACCESS_KEY_ID=
SUPABASE_STORAGE_S3_SECRET_ACCESS_KEY=

PUSH_WORKER_ENABLED=true
PUSH_WORKER_INTERVAL_MS=10000
PUSH_WORKER_MAX_DELIVERIES_PER_RUN=50
PUSH_WORKER_MAX_DELIVERY_ATTEMPTS=3
WEB_PUSH_VAPID_SUBJECT=mailto:admin@example.com
WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=

CLOUDFLARE_TUNNEL_TOKEN=change-me-cloudflare-tunnel-token

BACKUP_RETENTION_DAYS=7
BACKUP_CRON_SCHEDULE=17 3 * * *
RESTORE_VERIFY_MAX_AGE_HOURS=30
RESTORE_VERIFY_CRON_SCHEDULE=17 4 * * 0

MONITOR_DISK_WARN_PERCENT=85
MONITOR_BACKUP_MAX_AGE_HOURS=30
MONITOR_WEBHOOK_URL=
MONITOR_ALERT_ON_SUCCESS=false
MONITOR_CRON_SCHEDULE=*/5 * * * *
