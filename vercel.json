{
  "framework": null,
  "installCommand": "npm install",
  "buildCommand": "npm run build:web",
  "outputDirectory": "apps/app/dist",
  "redirects": [
    {
      "source": "/(.*)",
      "destination": "https://tongpin.fancah.tech/$1",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
