# Supabase Edge Function secrets. Set with `supabase secrets set`; do not expose these in Expo client env.
PUSH_DELIVERY_WORKER_SECRET=your-private-worker-secret
WEB_PUSH_VAPID_SUBJECT=mailto:admin@example.com
WEB_PUSH_VAPID_PUBLIC_KEY=your-web-push-vapid-public-key
WEB_PUSH_VAPID_PRIVATE_KEY=your-web-push-vapid-private-key

SILICONFLOW_API_KEY=your-siliconflow-api-key
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_PET_MODEL=deepseek-ai/DeepSeek-V4-Flash
PET_AI_DAILY_LIMIT=12
PET_AI_TIMEOUT_MS=4500
