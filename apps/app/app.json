{
  "expo": {
    "name": "同频跳动",
    "slug": "tongpin-heartbeat",
    "scheme": "tongpin",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "bundleIdentifier": "tech.fanch.tongpinheartbeat",
      "supportsTablet": false
    },
    "android": {
      "package": "tech.fanch.tongpinheartbeat"
    },
    "notification": {
      "icon": "./assets/icon.png",
      "color": "#C96F8F",
      "iosDisplayInForeground": true
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      "expo-status-bar",
      "expo-asset"
    ],
    "extra": {
      "eas": {
        "projectId": "6fa43146-003c-4a39-832b-55a9c66f8ad7"
      }
    },
    "owner": "fanchcc",
    "experiments": {
      "typedRoutes": true
    }
  }
}
